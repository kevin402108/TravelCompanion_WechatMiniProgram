.privacy-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  z-index: 9999;
  display: flex;
  justify-content: center;
  align-items: center;
}

.privacy-modal {
  width: 80%;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.2);
}

.modal-header {
  padding: 30rpx;
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  background: #f8f8f8;
  border-bottom: 1rpx solid #eee;
}

.modal-content {
  padding: 40rpx 30rpx;
  font-size: 30rpx;
  line-height: 1.6;
  color: #333;
}

.privacy-link {
  color: #07c160;
  text-decoration: underline;
}

.modal-buttons {
  display: flex;
  border-top: 1rpx solid #eee;
}

.btn-reject, .btn-agree {
  flex: 1;
  height: 90rpx;
  font-size: 32rpx;
  border-radius: 0;
}

.btn-reject {
  color: #ff3d3d;
  border-right: 1rpx solid #eee;
}

.btn-agree {
  color: #fff;
  background: #07c160;
}
