<view class="page">
  <view class="title-bar">个性化旅游方案</view>

  <view class="plan-summary">
    <text class="budget-label">预计花销：</text>
    <text class="budget-value">{{plan.budget}} 元</text>
  </view>

  <view class="arrange-list">
    <view class="arrange-card" wx:for="{{plan.arrange}}" wx:key="index">
      <view class="arrange-header">
        <text class="arrange-title">{{item.title}}</text>
      </view>
      <view class="arrange-detail">{{item.detail}}</view>
    </view>
  </view>

  <view class="empty-state" wx:if="{{!plan && emptyBoxShow}}">
    <text class="empty-icon">🧭</text>
    <text class="empty-title">暂无个性化方案</text>
    <text class="empty-subtitle">请填写表单生成您的专属行程</text>
  </view>

  <view class="round-btn history-btn" bindtap="navigateToHistory">查看历史旅游方案</view>
  <view class="round-btn ai-plan-btn" bindtap="navigateToAIPlan">{{plan ? '不满意?' : '没找到?'}}让AI帮你规划！</view>
</view>
