.page {
  padding: 28rpx 24rpx;
  background-color: #f5f7fa;
  min-height: 100vh;
}

.title-bar {
  text-align: center;
  font-size: 36rpx;
  font-weight: 600;
  color: #2c3e50;
  margin-bottom: 32rpx;
}

.plan-summary {
  background: #fff;
  border-radius:20rpx;
  padding: 32rpx;
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.05);
  margin-bottom: 32rpx;
}

.budget-label {
  font-size: 32rpx;
  color: #666;
  margin-right: 16rpx;
}

.budget-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #e74c3c;
}

.arrange-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.arrange-card {
  background: #fff;
  border-radius:20rpx;
  padding: 32rpx;
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.05);
}

.arrange-header {
  margin-bottom: 20rpx;
}

.arrange-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #222;
  display: block;
}

.arrange-detail {
  font-size:28rpx;
  color:#555;
  line-height:1.6;
  word-break: break-word;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
  background: #fff;
  border-radius:20rpx;
  color: #999;
}

.empty-icon { font-size: 64rpx; margin-bottom:24rpx; }
.empty-title { font-size: 36rpx; font-weight: 600; color: #333; margin-bottom:12rpx; }
.empty-subtitle { font-size:28rpx; color:#777; }

.round-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 40rpx auto 0;
  width: 100%;
  max-width: 600rpx;
  height: 88rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx; /* 哭途（렷 50% 角凜멕똑미땍，44rpx 뫘葵딧） */
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
  cursor: pointer;
}

.round-btn:active {
  transform: scale(0.98);
}

.ai-plan-btn {
  margin-bottom:15rpx;
  background-color: #4caf50;
  color: white;
  box-shadow: 0 6rpx 16rpx rgba(76, 175, 80, 0.2);
}

.ai-plan-btn:active {
  background-color: #388e3c;
}

.history-btn {
  margin-bottom:15rpx;
  background-color: #e1e1e1;
  color: #484848;
}
