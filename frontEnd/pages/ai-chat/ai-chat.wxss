page {
  background: linear-gradient(180deg, #E0F7FA 0%, #E8F5E9 60%, #FFFDE7 100%);
  color: #333;
}

.container {
  width: 100%;
  height: 100vh;
  background: transparent;
  display: flex;
  flex-direction: column;
  position: relative;
}

.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 999;
  width: 100%;
  box-sizing: border-box;
  /*box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);*/
  /*background: linear-gradient(135deg, #667eea 0%, #76c893 100%);*/
  backdrop-filter: blur(20rpx);
}

.nav-content {
  display: flex;
  align-items: center;
  height: 80rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.nav-left {
  width: 80rpx;
  display: flex;
  align-items: center;
}

.nav-left .iconfont {
  font-size: 40rpx;
  color: #fff;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.2);
}

.nav-center {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.nav-title {
  font-size: 36rpx;
  font-weight: bold;
  /*color: #fff;*/
  line-height: 1.5;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.2);
}

.nav-subtitle {
  font-size: 24rpx;
  /*color: rgba(255,255,255,0.9);*/
  line-height: 1.2;
}

.nav-right {
  width: 120rpx;
  display: flex;
  justify-content: space-between;
}

.nav-right .iconfont {
  font-size: 40rpx;
  color: #fff;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.2);
}

.content-area {
  /*flex: 1;*/
  box-sizing: border-box;
  padding: 30rpx 20rpx;
}

.message-list {
  height: 100%;
  width: 100%;
  padding-bottom: 20rpx;
  box-sizing: border-box;
}

.message-item {
  display: flex;
  margin-bottom: 40rpx;
  padding: 0rpx;
  position: relative;
  animation: slideIn 0.4s ease-out;
}

@keyframes slideIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.message-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  border: 4rpx solid #fff;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.15);
  background-color: #fff;
}

.message-avatar image {
  width: 100%;
  height: 100%;
}

.user-avatar {
  margin-right: 20rpx;
}

.ai-avatar {
  margin-left: 20rpx;
}

.message-content-wrapper {
  flex: 1;
  min-width: 0;
  padding: 0 10rpx;
  display: flex;
  flex-direction: column;
}

.user-message {
  align-items: flex-start;
}

.ai-message {
  align-items: flex-end;
}

.message-sender {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
  font-weight: 500;
}

.message-bubble {
  max-width: 65%;
  padding: 24rpx 30rpx;
  border-radius: 32rpx;
  position: relative;
  word-wrap: break-word;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
}

.user-bubble {
  background: linear-gradient(135deg, #667eea 0%, #76c893 100%);
  color: #fff;
  border-radius: 32rpx 32rpx 32rpx 8rpx;
  font-size: 30rpx;
  line-height: 1.6;
}

.ai-bubble {
  background: #fff;
  color: #333;
  border-radius: 32rpx 8rpx 32rpx 32rpx;
  font-size: 30rpx;
  line-height: 1.6;
  border: 2rpx solid rgba(102, 126, 234, 0.1);
}

.message-time {
  font-size: 22rpx;
  color: #999;
  margin-top: 10rpx;
  padding: 0 10rpx;
}

.typing-indicator {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #fff;
  border-radius: 32rpx;
  max-width: 120rpx;
  margin-left: 100rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
  animation: bounceIn 0.3s ease-out;
}

@keyframes bounceIn {
  0% {
    opacity: 0;
    transform: scale(0.8);
  }
  100% {
    opacity: 1;
    transform: scale(1);
  }
}

.typing-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background-color: #999;
  margin-right: 8rpx;
  animation: typingBounce 1.4s infinite;
}

.typing-dot:nth-child(2) {
  animation-delay: 0.2s;
}

.typing-dot:nth-child(3) {
  animation-delay: 0.4s;
  margin-right: 0;
}

@keyframes typingBounce {
  0%, 60%, 100% {
    transform: translateY(0);
  }
  30% {
    transform: translateY(-10rpx);
  }
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  height: 100%;
  padding: 40rpx 30rpx;
  box-sizing: border-box;
  padding-top: 40rpx;
}

.welcome-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
  animation: fadeInUp 0.6s ease-out;
  width: 100%;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.ai-avatar-large {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-bottom: 25rpx;
  position: relative;
  border: 6rpx solid #fff;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.3);
  background: linear-gradient(135deg, #667eea 0%, #76c893 100%);
  padding: 20rpx;
}

.ai-avatar-large image {
  width: 100%;
  height: 100%;
}

.avatar-glow {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(102, 126, 234, 0.4) 0%, transparent 70%);
  animation: glow 2s ease-in-out infinite;
}

@keyframes glow {
  0%, 100% {
    opacity: 0.5;
    transform: scale(1);
  }
  50% {
    opacity: 0.8;
    transform: scale(1.1);
  }
}

.welcome-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  text-align: center;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.1);
}

.welcome-subtext {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 30rpx;
  text-align: center;
  line-height: 1.5;
  width: 100%;
}

.feature-tags {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 16rpx;
  margin-top: 10rpx;
  width: 100%;
}

.tag {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 200, 147, 0.1) 100%);
  color: #667eea;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  border: 2rpx solid rgba(102, 126, 234, 0.2);
  font-weight: 500;
}

.quick-actions-vertical {
  display: flex;
  flex-direction: column;
  flex-shrink: 0;
  margin-top: 60rpx;
  gap: 20rpx;
  width: 100%;
  max-width: 680rpx;
  animation: fadeInUp 0.6s ease-out 0.2s both;
}

.section-title {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.action-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  background: #fff;
  color: #333;
  border-radius: 24rpx;
  font-size: 28rpx;
  border: 2rpx solid rgba(102, 126, 234, 0.2);
  padding: 24rpx 30rpx;
  transition: all 0.3s ease;
  margin: 0;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  position: relative;
  overflow: hidden;
}

.action-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.05) 0%, rgba(118, 200, 147, 0.05) 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.action-btn:active::before {
  opacity: 1;
}

.btn-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.action-btn:hover {
  border-color: #667eea;
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 20rpx rgba(102, 126, 234, 0.2);
}

.input-area {
  box-sizing: border-box;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  margin: 20rpx auto;
  padding: 20rpx 20rpx calc(env(safe-area-inset-bottom) + 20rpx);
  backdrop-filter: blur(10rpx);
  z-index: 1000;
}

.input-wrapper {
  display: flex;
  align-items: center;
  border-radius: 30rpx;
  padding: 10rpx;
  background: #fff;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.12);
  border: 2rpx solid rgba(102, 126, 234, 0.25);
  gap: 12rpx;
}

.input-left {
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.12) 0%, rgba(118, 200, 147, 0.12) 100%);
  transition: all 0.3s ease;
  flex-shrink: 0;
}

.icon-btn:active {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.2) 0%, rgba(118, 200, 147, 0.2) 100%);
  transform: scale(0.92);
}

.icon-btn .iconfont {
  font-size: 38rpx;
  color: #667eea;
}

.input-box {
  flex: 1;
  min-height: 72rpx;
  max-height: 180rpx;
  padding: 0 28rpx;
  font-size: 25rpx;
  background-color: transparent;
  border-radius: 36rpx;
  color: #333;
  border: none;
}

.input-box::placeholder {
  color: #999;
  font-style: normal;
}

.input-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.send-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  padding: 0 20rpx;
  height: 72rpx;
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #667eea 0%, #76c893 100%);
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.35);
  transition: all 0.3s ease;
  margin: 0;
  flex-shrink: 0;
}

.send-btn.active {
  opacity: 1;
  transform: scale(1);
}

.send-btn[disabled] {
  opacity: 0.5;
  transform: scale(0.95);
  box-shadow: none;
}

.send-icon {
  font-size: 34rpx;
  margin-right: 8rpx;
}

.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}