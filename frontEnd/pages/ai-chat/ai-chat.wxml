  <!-- 内容区域 -->
  <view class="content-area" style="margin-top: {{navBarHeight}}px;">
    <!-- 消息列表 -->
    <block wx:if="{{messages.length > 0}}">
      <scroll-view class="message-list" style="height: {{contentAreaHeight}}px;" scroll-y="true" scroll-into-view="{{scrollToView}}" enable-back-to-top="true">
        <view class="message-item" wx:for="{{messages}}" wx:key="index" id="msg-{{index}}">
          <view class="message-avatar user-avatar" wx:if="{{item.sender === '您'}}">
            <image src="/images/ai-chat/user-default-avatar.png" mode="aspectFill"></image>
          </view>
          <view class="message-content-wrapper {{item.sender === '您' ? 'user-message' : 'ai-message'}}">
            <view class="message-sender">{{item.sender}}</view>
            <view class="message-bubble message-content {{item.sender === '您' ? 'user-bubble' : 'ai-bubble'}}">
              <text>{{item.content}}</text>
            </view>
            <view class="message-time">{{item.time}}</view>
          </view>
          <view class="message-avatar ai-avatar" wx:if="{{item.sender !== '您'}}">
            <image src="/images/ai-chat/ai-avatar.png" mode="aspectFill"></image>
          </view>
        </view>

        <!-- 加载动画 -->
        <view class="typing-indicator" wx:if="{{isTyping}}">
          <view class="typing-dot"></view>
          <view class="typing-dot"></view>
          <view class="typing-dot"></view>
        </view>
      </scroll-view>
    </block>

    <!-- 空状态 -->
    <block wx:else>
      <view class="empty-state">
        <view class="welcome-card">
          <view class="ai-avatar-large">
            <image src="/images/ai-chat/ai-avatar.png" mode="aspectFit"></image>
            <view class="avatar-glow"></view>
          </view>
          <view class="welcome-text">你好呀！我是你的 AI 旅行助手 ✈️</view>
          <view class="welcome-subtext">我可以帮您规划行程、推荐景点、解答旅行问题</view>

          <view class="feature-tags">
            <view class="tag">🗺️ 路线规划</view>
            <view class="tag">🍜 美食攻略</view>
            <view class="tag">📸 景点介绍</view>
          </view>
        </view>

        <view class="quick-actions-vertical">
          <button class="action-btn" data-action="travel-plan" bindtap="onQuickActionTap">
            <text class="btn-icon">📋</text>
            <text>帮我生成旅游路线</text>
          </button>
          <button class="action-btn" data-action="route-recommend" bindtap="onQuickActionTap">
            <text class="btn-icon">🎯</text>
            <text>帮我规划下旅游路线</text>
          </button>
          <button class="action-btn" data-action="destination-info" bindtap="onQuickActionTap">
            <text class="btn-icon">🌍</text>
            <text>介绍下这个地方</text>
          </button>
        </view>
      </view>
    </block>
  </view>

  <!-- 底部输入区域 -->
  <view class="input-area safe-area-bottom">
    <view class="input-wrapper">
      <view class="input-left">
        <view class="icon-btn" bindtap="onMicrophoneTap">
          <text class="iconfont icon-yuyin"></text>
        </view>
      </view>
      <input 
        class="input-box" 
        placeholder="问我与旅游相关的问题吧~"
        value="{{inputValue}}" 
        bindinput="onInput" 
        bindconfirm="onSend"
        maxlength="500"
        confirm-type="send"
      />
      <view class="input-right">
        <button class="send-btn {{hasInput ? 'active' : ''}}" bindtap="onSend" disabled="{{!hasInput}}">
          <text class="send-icon">✈️</text>
          <text class="send-text">发送</text>
        </button>
      </view>
    </view>
  </view>
</view>