page {
  background:linear-gradient(to bottom,#dafbda,#ffffff);
  color:#333;
}

.slider {
  height: 30vh;
}

.slider image {
    position: absolute;
    width: 100%;
    height: 100%;
    background-color: rgba(255, 255, 255, 0.502);
    left: 0;
    top: 0;
}

.title {
  margin:30rpx auto;
  width:95vw;
  height:4vh;
  line-height: 4vh;
  text-align: center;
  font-size: 30rpx;
  font-weight: bold;
  border:2rpx solid #999;
  border-radius: 2vh;
}

.common-func .bd {
  width: 100%;
  min-height: 10vh;
  margin: 20rpx auto;
  display: flex;
  flex-wrap: wrap; 
  justify-content: space-around;
  align-items: center;
  gap: 20rpx; 
  padding: 0 10rpx;  
}

.common-func .bd > view {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  width: calc(40% - 20rpx);
  max-width: 200rpx;
  padding: 5rpx 5rpx;
  background-color: #e3f2fd;
  border: 2rpx solid #73b7fc;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.1);
  transition: all 0.2s ease-in-out;
}

.common-func .bd > view:hover {
  transform: translateY(-4rpx);
}

.common-func .bd image {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 16rpx; 
}

.common-func .bd .func-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.notice .bd .article{
  margin: 5rpx 0;
  padding: 10rpx ; 
  display: flex;
  width: 100%;
  border: 4rpx solid #dfdfdf;
  border-left:0;
  border-right:0;
  background-color: #f5f5f5;
}


.notice .bd image {
  padding: 5rpx;
  width: 25vw;
  height: 16vh;
}

.notice .bd .right {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  flex: 1;
  padding: 10rpx;
  text-align: left;
  font-size: 35rpx;
  color: #333;
}

.notice .right .header {
  font-weight: bold;
}

.notice .right .content {
  margin: 10rpx 0;
  font-size: 28rpx;
  color: #999;
}

.notice .right .pub-date {
  margin-top: 10rpx;
  font-size: 24rpx;
  color:#999;
}

.footer {
  margin: 50rpx 0;
  width: 100vw;
  text-align: center;
  font-size: 40rpx;
  color:#999
}








