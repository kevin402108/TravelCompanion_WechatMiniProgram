.tip {
    display: flex;
    justify-content: center;
    align-items: center;
    margin: 20rpx 0;
}

.container {
    padding: 10rpx;
}

.form-item {
    margin: 20rpx 0;
}

.form-item .label {
    font-size: 35rpx;
    color:#636363;
}

.input-box {
    margin-top: 10rpx;
    width: 96%;
    padding: 10rpx;
    border: 2rpx solid #999;
    border-radius: 10rpx;
}

.value-show {
    align-items: center;
    font-size: 32rpx;
    color: #999;
    margin-top: 20rpx;
}

.value-show text {
    color:#333;
    font-weight: bold;
}

.slider-box {
    width: 90%;
    margin: 25rpx auto;
}

.btn-set {
    display: flex;
    justify-content: space-between;
}

.btn-set button {
    margin-top: 10rpx;    
    padding: 10rpx 10rpx;
    color: white;
    border-radius: 15rpx;
    width: 300rpx;
}

.submit-btn {
    background-color: #4CAF50;
}

.reset-btn {
    background-color: #f44336;
}

.round-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 40rpx auto 0;
    width: 100%;
    max-width: 600rpx;
    height: 88rpx;
    text-align: center;
    font-size: 32rpx;
    font-weight: 500;
    border-radius: 44rpx; /* 椭圆（非 50% 是因高度固定，44rpx 更协调） */
    box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.08);
    transition: all 0.3s ease;
    cursor: pointer;
}

.round-btn:active {
    transform: scale(0.98);
}

.ai-plan-btn {
    background-color: #4caf50;
    color: white;
    box-shadow: 0 6rpx 16rpx rgba(76, 175, 80, 0.2);
}

.ai-plan-btn:active {
    background-color: #388e3c;
}

.history-btn {
    background-color: #e1e1e1;
    color: #484848;
}



