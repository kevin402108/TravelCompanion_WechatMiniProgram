<view class="page">
  <view class="title-bar" wx:if="{{route.length !== 0}}">已为您生成以下旅游路线</view>
  <view class="round-btn history-btn" wx:if="{{route.length !== 0}}" bindtap="navigateToHistory">查看历史生成路线</view>
  <view class="round-btn ai-plan-btn" wx:if="{{route.length !== 0}}" bindtap="navigateToAIPlan">不满意？让AI帮你规划！</view>
  <view class="spot-list">
    <view class="spot-card" wx:for="{{route}}" wx:key="id">
      <text class="delete-icon" bindtap="deleteSpot" data-id="{{item.id}}">×</text>

      <view class="spot-name">{{item.name}}</view>
      <view class="spot-desc">{{item.description}}</view>
    </view>
  </view>

  <view class="empty-state" wx:if="{{route.length === 0 && emptyBoxShow}}">
    <text class="empty-icon">🧭</text>
    <text class="empty-title">暂无符合需求的旅游路线</text>
    <text class="empty-subtitle">请调整筛选条件后重试</text>
    <view class="round-btn history-btn" bindtap="navigateToHistory">查看历史生成路线</view>
    <view class="round-btn ai-plan-btn" bindtap="navigateToAIPlan">未找到？让AI帮你规划！</view>
  </view>
</view>
