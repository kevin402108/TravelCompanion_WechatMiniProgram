<view class="page">
  <view class="empty-state" wx:if="{{plans.length === 0 && loaded}}">
    <text class="empty-icon">📅</text>
    <text class="empty-title">暂无历史方案</text>
    <text class="empty-subtitle">您尚未生成任何个性化旅游方案</text>
  </view>

  <view class="plans-list" wx:else>
    <view class="plan-card" wx:for="{{plans}}" wx:key="id">
      <text class="create-time">{{item.create_time}}</text>
      <view class="info-section">
        <text class="field">💰 预计花销：{{item.budget}} 元</text>
        <text class="field">🗓 天数：{{item.duration}}</text>
        <text class="field">🎯 偏好：{{item.preference || '无'}}</text>
      </view>
      <view class="btn-row">
        <text class="detail-btn" bindtap="showPlanDetail" data-id="{{item.id}}">查看详情</text>
        <text class="delete-btn" bindtap="confirmDelete" data-id="{{item.id}}">删除</text>
      </view>
    </view>
  </view>

  <view class="modal-overlay" wx:if="{{showDetailModal}}">
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">方案详情</text>
      </view>
      <view class="modal-body">
        <text class="line">💰 预计花销：{{detailPlan.budget}} 元</text>
        <text class="line">🗓 天数：{{detailPlan.duration}}</text>
        <text class="line">🎯 偏好：{{detailPlan.preference || '无'}}</text>
        <text class="line">🕒 创建时间：{{detailPlan.create_time}}</text>
        <text class="line">📋 行程概要：</text>
        <block wx:for="{{detailPlan.arrange}}" wx:key="index">
          <text class="line">• {{item.title}}</text>
        </block>
      </view>
      <button class="confirm-btn" bindtap="hideDetailModal">关闭</button>
    </view>
  </view>
</view>
